# ---- Database ----
# Local dev uses the OrbStack/docker postgres container on port 5544 (see docker-compose.yml)
DATABASE_URL="postgresql://augur:augur@localhost:5544/augur?schema=public"

# ---- Data source ----
# seed  = load the bundled demo markets (offline, deterministic) — great for a first run
# live  = connect to real Polymarket (WebSocket) + Kalshi (REST polling)
DATA_SOURCE="seed"

# Kalshi REST polling interval (ms) when DATA_SOURCE=live
KALSHI_POLL_MS="4000"

# Base URLs (override if a provider migrates domains)
POLYMARKET_GAMMA_URL="https://gamma-api.polymarket.com"
POLYMARKET_CLOB_URL="https://clob.polymarket.com"
POLYMARKET_WS_URL="wss://ws-subscriptions-clob.polymarket.com/ws/market"
KALSHI_API_URL="https://external-api.kalshi.com/trade-api/v2"

# ---- Agent / LLM (via OpenRouter) ----
# deterministic = port of the prototype decision-tree, no network, zero cost
# llm           = real multi-agent calls through OpenRouter
AGENT_ENGINE="deterministic"
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
LLM_MODEL_PRIMARY="google/gemini-3.5-flash"
LLM_MODEL_FALLBACK="deepseek/deepseek-v4-flash"
