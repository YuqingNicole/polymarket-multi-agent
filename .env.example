# ── LLM ──────────────────────────────────────────────────────────────────────
# Required for multi-agent LLM analysis (MacroAgent / TechAgent / ArbAgent / JudgeAgent)
# Get your key at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_key_here

# Model to use for all agents. Recommended options:
#   anthropic/claude-3-5-haiku  (fast, cheap, good enough for most markets)
#   anthropic/claude-3-5-sonnet (higher quality, slower)
#   openai/gpt-4o-mini          (cheap alternative)
OPENROUTER_MODEL=anthropic/claude-3-5-haiku

# ── Data engine ───────────────────────────────────────────────────────────────
# 'live'  = fetch real Polymarket + Kalshi data (default for scanner)
# 'seed'  = use local seed data (for development / testing without API calls)
DATA_SOURCE=live

# ── Scanner behaviour ─────────────────────────────────────────────────────────
# Minimum composite score (0-100) to include in results
SCANNER_MIN_SCORE=30

# Max opportunities to return per scan
SCANNER_MAX_RESULTS=20

# Run LLM analysis on top N opportunities per scan (set to 0 to disable)
SCANNER_LLM_TOP_N=3

# Scan interval in seconds when running in --loop mode
SCANNER_INTERVAL_SEC=120

# Minimum 24h volume (USD) for a market to be considered
SCANNER_MIN_VOL24H=5000

# Minimum cross-platform spread (cents) to flag as arbitrage
SCANNER_MIN_SPREAD_CENTS=3

# ── Polymarket API ────────────────────────────────────────────────────────────
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# ── Kalshi API ────────────────────────────────────────────────────────────────
# No API key required for public market data
KALSHI_API_URL=https://trading-api.kalshi.com/trade-api/v2
KALSHI_POLL_MS=4000

# ── Database (optional — only needed for the web UI / historical storage) ─────
# DATABASE_URL=postgresql://user:pass@localhost:5544/augur?schema=public
